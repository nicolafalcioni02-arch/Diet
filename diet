                .laf-input.number:focus {
                    border-color: #00C853;
                    background: #F2FFF7;
                    color: #00C853;
                }

                .laf-row {
                    transition: background 0.2s ease;
                }

                .laf-row:hover {
                    background: #FAFAFC;
                }
                    .preview-badge {
                    background: #F2F2F7;
                    padding: 4px 10px;
                    border-radius: 8px;
                    font-size: 11px;
                    font-weight: 600;
                    color: #1D1D1F;
                    display: flex;
                    justify-content: space-between;
