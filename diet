                .report-comment-box { background: #F9F9FB; padding: 20px; border-radius: 16px; font-size: 13px; color: #1D1D1F; font-style: italic; border-left: 4px solid #00C853; height: 100%; line-height: 1.6; overflow-y: auto; }
