    // --- COMPONENTE AUSILIARIO: PROGRESS BAR ---
    // Definito all'interno per accedere comodamente agli stili
    const renderProgressBar = (label, current, max, color) => {
        const pct = Math.min((current / (max || 1)) * 100, 100) || 0;
        const isOver = current > max;
        return (
            <div style={{ marginBottom: '12px' }}>
                <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: '10px', fontWeight: 700, color: '#86868B', textTransform: 'uppercase', marginBottom: '4px' }}>
                    <span>{label}</span>
                    <span style={{ color: isOver ? '#FF3B30' : '#1D1D1F' }}>
                        {current.toFixed(0)} / {max}
                    </span>
                </div>
                <div style={{ width: '100%', height: '6px', background: '#E5E5EA', borderRadius: '3px', overflow: 'hidden' }}>
                    <div style={{ width: `${pct}%`, height: '100%', borderRadius: '3px', background: isOver ? '#FF3B30' : color, transition: 'width 0.4s ease' }} />
                </div>
            </div>
        );
    };

    // --- STATI PER DASHBOARD E MODALE SMART ---
    const [isSmartOpen, setIsSmartOpen] = useState(false);
    const [smartConfig, setSmartConfig] = useState({ 
        type: 'bar',        // 'bar', 'pie', 'line', 'mixed', '3d', 'radar'
        metric: 'kcal',     // 'kcal', 'macro', 'p', 'c', 'f', 'weight'
        scope: 'activeDay', // 'activeDay', 'allDays'
        comment: '' 
    });
    

    // --- MOTORE PLOTLY.JS (Senza Menu fluttuante e con etichette chiare) ---
    const plotRef = useRef(null);

    useEffect(() => {
        if (!isSmartOpen || !window.Plotly || !plotRef.current) return;

        // 1. GESTIONE DELLO SCOPE E AGGREGAZIONE DATI
        let labels = [];
        let dataMap = { kcal: [], p: [], c: [], f: [], weight: [] };

        if (smartConfig.scope === 'activeDay') {
            if (!activeDay) return;
            const meals = activeDay.meals || [];
            labels = meals.map((m, i) => m.title || `Pasto ${i + 1}`);
            
            dataMap.kcal = meals.map(m => calculateTotals(m.items).kcal);
            dataMap.p = meals.map(m => calculateTotals(m.items).p);
            dataMap.c = meals.map(m => calculateTotals(m.items).c);
            dataMap.f = meals.map(m => calculateTotals(m.items).f);
            dataMap.weight = meals.map(m => m.items.reduce((acc, it) => acc + (Number(it.weight) || 0), 0));
        } else {
            labels = dietDays.map((d, i) => d.title || `Giorno ${i + 1}`);
            
            dietDays.forEach(day => {
                const dayItems = day.meals.flatMap(m => m.items);
                const dayTotals = calculateTotals(dayItems);
                dataMap.kcal.push(dayTotals.kcal);
                dataMap.p.push(dayTotals.p);
                dataMap.c.push(dayTotals.c);
                dataMap.f.push(dayTotals.f);
                dataMap.weight.push(dayItems.reduce((acc, it) => acc + (Number(it.weight) || 0), 0));
            });
        }

        // 2. PALETTE COLORI FISSA (Stile Apple Pro)
        const cColor = '#1D1D1F'; // Nero per Carboidrati o Kcal
        const pColor = '#00C853'; // Verde per Proteine o Valori primari
        const fColor = '#86868B'; // Grigio per Grassi
        const accColor = '#007AFF'; // Blu per metriche di confronto (es. Peso nel grafico misto)
        
        const colorMap = { kcal: cColor, p: pColor, c: cColor, f: fColor, weight: accColor };
        const nameMap = { kcal: 'Kcal', p: 'Proteine (g)', c: 'Carbo (g)', f: 'Grassi (g)', weight: 'Volume Cibo (g)' };

        // 3. COSTRUZIONE DEL LAYOUT BASE
        let plotData = [];
        let layout = { 
            autosize: true, 
            margin: { t: 40, l: 60, r: 60, b: 60 }, // Margini allargati per mostrare bene le etichette degli assi
            paper_bgcolor: 'transparent',
            plot_bgcolor: 'transparent',
            font: { family: '-apple-system, BlinkMacSystemFont, sans-serif', color: '#86868B' },
            showlegend: true,
            legend: { orientation: 'h', y: -0.2 },
            xaxis: { tickangle: -45 }
        };

        // 4. RENDERING CONDIZIONALE DEI TIPI DI GRAFICO
        if (smartConfig.type === 'bar' || smartConfig.type === 'line') {
            const type = smartConfig.type === 'bar' ? 'bar' : 'scatter';
            const mode = smartConfig.type === 'line' ? 'lines+markers' : undefined;

            if (smartConfig.metric === 'macro') {
                plotData.push({ x: labels, y: dataMap.c, type, mode, name: nameMap.c, marker: { color: cColor }, line: { color: cColor, width: 2 } });
                plotData.push({ x: labels, y: dataMap.p, type, mode, name: nameMap.p, marker: { color: pColor }, line: { color: pColor, width: 2 } });
                plotData.push({ x: labels, y: dataMap.f, type, mode, name: nameMap.f, marker: { color: fColor }, line: { color: fColor, width: 2 } });
                if (smartConfig.type === 'bar') layout.barmode = 'stack';
                layout.yaxis = { title: { text: 'Grammi (g)' } };
            } else {
                const m = smartConfig.metric;
                plotData.push({ x: labels, y: dataMap[m], type, mode, name: nameMap[m], marker: { color: colorMap[m] }, line: { color: colorMap[m], width: 3 }, fill: smartConfig.type === 'line' ? 'tozeroy' : 'none' });
                layout.yaxis = { title: { text: nameMap[m] } };
            }
        } 
        
        else if (smartConfig.type === 'pie') {
            if (smartConfig.metric === 'macro') {
                const sumPro = dataMap.p.reduce((a,b) => a+b, 0);
                const sumCar = dataMap.c.reduce((a,b) => a+b, 0);
                const sumFat = dataMap.f.reduce((a,b) => a+b, 0);
                plotData.push({ labels: [nameMap.c, nameMap.p, nameMap.f], values: [sumCar, sumPro, sumFat], type: 'pie', hole: 0.4, marker: { colors: [cColor, pColor, fColor] }, textinfo: 'label+percent' });
            } else {
                const m = smartConfig.metric;
                plotData.push({ labels: labels, values: dataMap[m], type: 'pie', hole: 0.4, textinfo: 'label+percent', name: nameMap[m] });
            }
        }

        // GRAFICO MISTO: Kcal (Y primario) vs Volume (Y secondario)
        else if (smartConfig.type === 'mixed') {
            plotData.push({ x: labels, y: dataMap.kcal, type: 'bar', name: 'Kcal Totali', marker: { color: cColor }, yaxis: 'y1' });
            plotData.push({ x: labels, y: dataMap.weight, type: 'scatter', mode: 'lines+markers', name: 'Volume Cibo (g)', line: { color: accColor, width: 3 }, marker: { size: 8 }, yaxis: 'y2' });
            
            layout.yaxis = { title: { text: 'Calorie (Kcal)', font: { color: cColor } }, tickfont: { color: cColor } };
            layout.yaxis2 = { title: { text: 'Volume (g)', font: { color: accColor } }, tickfont: { color: accColor }, overlaying: 'y', side: 'right' };
        }

        // GRAFICO RADAR
        else if (smartConfig.type === 'radar') {
            labels.forEach((label, i) => {
                plotData.push({
                    type: 'scatterpolar',
                    r: [dataMap.c[i], dataMap.p[i], dataMap.f[i], dataMap.c[i]], 
                    theta: ['Carbo (g)', 'Proteine (g)', 'Grassi (g)', 'Carbo (g)'],
                    fill: 'toself',
                    name: label
                });
            });
            layout.polar = { radialaxis: { visible: true, range: [0, Math.max(...dataMap.c, ...dataMap.p, ...dataMap.f) * 1.2] } };
        }

        // GRAFICO 3D (Ora con le etichette chiare per X, Y e Z)
        else if (smartConfig.type === '3d') {
            plotData.push({
                x: dataMap.c, y: dataMap.p, z: dataMap.f,
                mode: 'markers+text', type: 'scatter3d',
                text: labels, textposition: 'top center',
                marker: { size: 8, color: dataMap.kcal, colorscale: 'Viridis', opacity: 0.8, showscale: true, colorbar: { title: 'Kcal' } }
            });
            
            layout.scene = {
                xaxis: { title: { text: 'Carboidrati (g)' } }, 
                yaxis: { title: { text: 'Proteine (g)' } }, 
                zaxis: { title: { text: 'Grassi (g)' } }
            };
            layout.margin = { l: 0, r: 0, b: 0, t: 0 };
        }

        window.Plotly.purge(plotRef.current);
        
        // Configurazione finale: displayModeBar: false nasconde definitivamente la toolbar fluttuante
        window.Plotly.newPlot(plotRef.current, plotData, layout, { displayModeBar: false, responsive: true });

    }, [isSmartOpen, activeDay, smartConfig, dietDays]);

    // --- STATI PER I REPORT SALVATI ---
    const [savedReports, setSavedReports] = useState(() => {
        const stored = localStorage.getItem('diet_saved_reports');
        return stored ? JSON.parse(stored) : [];
    });

    useEffect(() => {
        localStorage.setItem('diet_saved_reports', JSON.stringify(savedReports));
    }, [savedReports]);

    // --- GESTIONE SALVATAGGIO REPORT ---
    const saveSmartReport = () => {
        const newReport = {
            id: genId(),
            date: new Date().toLocaleDateString('it-IT'),
            dayId: activeDay ? activeDay.id : null,
            dayTitle: smartConfig.scope === 'activeDay' ? (activeDay?.title || 'Giorno') : 'Panoramica Settimanale',
            config: { ...smartConfig }
        };
        setSavedReports(prev => [newReport, ...prev]); // Aggiunge in cima alla lista
        setIsSmartOpen(false);
        // Resetta il commento per non portarselo dietro al prossimo utilizzo
        setSmartConfig(prev => ({ ...prev, comment: '' })); 
    };

    const deleteReport = (reportId) => {
        if(window.confirm("Vuoi eliminare definitivamente questo report?")) {
            setSavedReports(prev => prev.filter(r => r.id !== reportId));
        }
    };

    // --- SOTTO-COMPONENTE: GENERATORE MINI GRAFICI ---
    const MiniReportChart = ({ report, allDays }) => {
        const miniPlotRef = useRef(null);

        useEffect(() => {
            if (!window.Plotly || !miniPlotRef.current) return;

            const config = report.config;
            let labels = [];
            let dataMap = { kcal: [], p: [], c: [], f: [], weight: [] };

            // Ricostruzione dati in base allo scope salvato
            if (config.scope === 'activeDay') {
                const targetDay = allDays.find(d => d.id === report.dayId) || allDays[0];
                if (!targetDay) return;
                labels = (targetDay.meals || []).map((m, i) => m.title || `Pasto ${i + 1}`);
                dataMap.kcal = targetDay.meals.map(m => calculateTotals(m.items).kcal);
                dataMap.p = targetDay.meals.map(m => calculateTotals(m.items).p);
                dataMap.c = targetDay.meals.map(m => calculateTotals(m.items).c);
                dataMap.f = targetDay.meals.map(m => calculateTotals(m.items).f);
                dataMap.weight = targetDay.meals.map(m => m.items.reduce((acc, it) => acc + (Number(it.weight) || 0), 0));
            } else {
                labels = allDays.map((d, i) => d.title || `Giorno ${i + 1}`);
                allDays.forEach(day => {
                    const dayItems = day.meals.flatMap(m => m.items);
                    const dayTotals = calculateTotals(dayItems);
                    dataMap.kcal.push(dayTotals.kcal);
                    dataMap.p.push(dayTotals.p);
                    dataMap.c.push(dayTotals.c);
                    dataMap.f.push(dayTotals.f);
                    dataMap.weight.push(dayItems.reduce((acc, it) => acc + (Number(it.weight) || 0), 0));
                });
            }

            const cColor = '#1D1D1F'; const pColor = '#00C853'; const fColor = '#86868B'; const accColor = '#007AFF';
            let plotData = [];
            let layout = { 
                autosize: true, margin: { t: 10, l: 30, r: 30, b: 30 },
                paper_bgcolor: 'transparent', plot_bgcolor: 'transparent',
                font: { family: '-apple-system, BlinkMacSystemFont, sans-serif', color: '#86868B', size: 10 },
                showlegend: false // Legenda nascosta per le card compatte
            };

            // Mappatura compatta dei grafici
            if (config.type === 'bar' || config.type === 'line') {
                const type = config.type === 'bar' ? 'bar' : 'scatter';
                const mode = config.type === 'line' ? 'lines+markers' : undefined;
                if (config.metric === 'macro') {
                    plotData.push({ x: labels, y: dataMap.c, type, mode, marker: { color: cColor }, line: { color: cColor } });
                    plotData.push({ x: labels, y: dataMap.p, type, mode, marker: { color: pColor }, line: { color: pColor } });
                    plotData.push({ x: labels, y: dataMap.f, type, mode, marker: { color: fColor }, line: { color: fColor } });
                    if (config.type === 'bar') layout.barmode = 'stack';
                } else {
                    const col = config.metric === 'weight' ? accColor : (config.metric === 'p' ? pColor : cColor);
                    plotData.push({ x: labels, y: dataMap[config.metric], type, mode, marker: { color: col }, line: { color: col }, fill: config.type === 'line' ? 'tozeroy' : 'none' });
                }
            } else if (config.type === 'pie') {
                if (config.metric === 'macro') {
                    plotData.push({ labels: ['C', 'P', 'F'], values: [dataMap.c.reduce((a,b)=>a+b,0), dataMap.p.reduce((a,b)=>a+b,0), dataMap.f.reduce((a,b)=>a+b,0)], type: 'pie', hole: 0.5, marker: { colors: [cColor, pColor, fColor] }, textinfo: 'percent' });
                } else {
                    plotData.push({ labels: labels, values: dataMap[config.metric], type: 'pie', hole: 0.5, textinfo: 'percent' });
                }
            } else if (config.type === 'mixed') {
                plotData.push({ x: labels, y: dataMap.kcal, type: 'bar', marker: { color: cColor }, yaxis: 'y1' });
                plotData.push({ x: labels, y: dataMap.weight, type: 'scatter', mode: 'lines+markers', line: { color: accColor }, yaxis: 'y2' });
                layout.yaxis2 = { overlaying: 'y', side: 'right', showticklabels: false };
            } else if (config.type === 'radar') {
                labels.forEach((label, i) => {
                    plotData.push({ type: 'scatterpolar', r: [dataMap.c[i], dataMap.p[i], dataMap.f[i], dataMap.c[i]], theta: ['C', 'P', 'F', 'C'], fill: 'toself' });
                });
                layout.polar = { radialaxis: { visible: false } };
            } else if (config.type === '3d') {
                plotData.push({ x: dataMap.c, y: dataMap.p, z: dataMap.f, mode: 'markers', type: 'scatter3d', marker: { size: 5, color: dataMap.kcal, colorscale: 'Viridis' } });
                layout.margin = { l: 0, r: 0, b: 0, t: 0 };
            }

            window.Plotly.purge(miniPlotRef.current);
            window.Plotly.newPlot(miniPlotRef.current, plotData, layout, { displayModeBar: false, responsive: true, staticPlot: true }); // staticPlot disabilita interazioni pesanti sulle card
        }, [report, allDays]);

        return <div ref={miniPlotRef} style={{ width: '100%', height: '220px', marginTop: 'auto' }}></div>;
    };

    

    

