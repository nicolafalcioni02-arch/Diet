                        'energy_kj', 'image', 'name', 'category', 'scientific_name', 
                        'english_name', 'info'
                    ];
                    
                    return v > 0 && 
                        !patientTargets[k] && 
                        k !== 'energy_kcal' && 
                        !technicalFields.includes(k);
