                    background: #FFFFFF; border-radius: 24px; padding: 20px; 
                    border: 1px solid #E5E5EA; display: flex; flex-direction: column; 
                }
                
                .bar-label-sigla {
                    font-size: 10px; font-weight: 900; color: #86868B; 
                    margin-top: 6px; text-transform: uppercase;
                }

                /* --- LEGENDE E VALORI --- */
