                                value={dbSearch} onChange={e => setDbSearch(e.target.value)} 
                                style={{ width: '100%', padding: '12px 16px', borderRadius: '12px', border: '1px solid #E5E5EA', fontSize: '14px', fontWeight: 600, background: '#F9F9FB', outline: 'none' }} 
                            />
                        </div>

                        {/* TABELLA DATABASE (Modificabile in linea) */}
                        <div style={{ flex: 1, overflowY: 'auto', padding: '0 40px 20px' }}>
                            <table style={{ width: '100%', borderCollapse: 'collapse', fontSize: '14px' }}>
                                <thead>
                                    <tr>
                                        <th style={{ width:'30%', position: 'sticky', top: 0, background: '#FFFFFF', padding: '12px 10px', textAlign: 'left', fontSize: '11px', textTransform: 'uppercase', color: '#86868B', borderBottom: '2px solid #F0F0F2', zIndex: 2 }}>Alimento</th>
                                        <th style={{ width:'20%', position: 'sticky', top: 0, background: '#FFFFFF', padding: '12px 10px', textAlign: 'left', fontSize: '11px', textTransform: 'uppercase', color: '#86868B', borderBottom: '2px solid #F0F0F2', zIndex: 2 }}>Categoria</th>
                                        <th style={{ width:'12%', position: 'sticky', top: 0, background: '#FFFFFF', padding: '12px 10px', textAlign: 'left', fontSize: '11px', textTransform: 'uppercase', color: '#86868B', borderBottom: '2px solid #F0F0F2', zIndex: 2 }}>Kcal</th>
                                        <th style={{ width:'12%', position: 'sticky', top: 0, background: '#FFFFFF', padding: '12px 10px', textAlign: 'left', fontSize: '11px', textTransform: 'uppercase', color: '#86868B', borderBottom: '2px solid #F0F0F2', zIndex: 2 }}>Pro</th>
                                        <th style={{ width:'12%', position: 'sticky', top: 0, background: '#FFFFFF', padding: '12px 10px', textAlign: 'left', fontSize: '11px', textTransform: 'uppercase', color: '#86868B', borderBottom: '2px solid #F0F0F2', zIndex: 2 }}>Car</th>
                                        <th style={{ width:'12%', position: 'sticky', top: 0, background: '#FFFFFF', padding: '12px 10px', textAlign: 'left', fontSize: '11px', textTransform: 'uppercase', color: '#86868B', borderBottom: '2px solid #F0F0F2', zIndex: 2 }}>Fat</th>
                                        <th style={{ width:'5%', position: 'sticky', top: 0, background: '#FFFFFF', padding: '12px 10px', borderBottom: '2px solid #F0F0F2', zIndex: 2 }}></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {foodDB.map((f, index) => {
                                        // Filtro di ricerca testuale
                                        if (dbSearch && !f.name.toLowerCase().includes(dbSearch.toLowerCase()) && !f.category.toLowerCase().includes(dbSearch.toLowerCase())) return null;
                                        return (
                                            <tr key={index} style={{ borderBottom: '1px solid #F5F5F7' }}>
                                                <td style={{ padding: '8px' }}><input value={f.name} onChange={e => updateDbFood(index, 'name', e.target.value)} style={{ width: '100%', border: '1px solid transparent', background: 'transparent', padding: '8px', borderRadius: '6px', fontSize: '14px', fontWeight: 600, color: '#1D1D1F', outline: 'none' }}/></td>
                                                <td style={{ padding: '8px' }}><input value={f.category} onChange={e => updateDbFood(index, 'category', e.target.value)} style={{ width: '100%', border: '1px solid transparent', background: 'transparent', padding: '8px', borderRadius: '6px', fontSize: '14px', color: '#86868B', outline: 'none' }}/></td>
                                                <td style={{ padding: '8px' }}><input type="number" value={f.kcal} onChange={e => updateDbFood(index, 'kcal', e.target.value)} style={{ width: '100%', border: '1px solid transparent', background: 'transparent', padding: '8px', borderRadius: '6px', fontSize: '14px', fontWeight: 700, color: '#1D1D1F', outline: 'none' }}/></td>
                                                <td style={{ padding: '8px' }}><input type="number" value={f.p} onChange={e => updateDbFood(index, 'p', e.target.value)} style={{ width: '100%', border: '1px solid transparent', background: 'transparent', padding: '8px', borderRadius: '6px', fontSize: '14px', color: '#1D1D1F', outline: 'none' }}/></td>
                                                <td style={{ padding: '8px' }}><input type="number" value={f.c} onChange={e => updateDbFood(index, 'c', e.target.value)} style={{ width: '100%', border: '1px solid transparent', background: 'transparent', padding: '8px', borderRadius: '6px', fontSize: '14px', color: '#1D1D1F', outline: 'none' }}/></td>
                                                <td style={{ padding: '8px' }}><input type="number" value={f.f} onChange={e => updateDbFood(index, 'f', e.target.value)} style={{ width: '100%', border: '1px solid transparent', background: 'transparent', padding: '8px', borderRadius: '6px', fontSize: '14px', color: '#1D1D1F', outline: 'none' }}/></td>
                                                <td style={{ padding: '8px', textAlign: 'center' }}>
                                                    <button onClick={() => deleteFoodDB(index)} style={{ background: 'transparent', border: 'none', color: '#FF3B30', fontWeight: 800, cursor: 'pointer', padding: '8px' }}>X</button>
                                                </td>
                                            </tr>
                                        )
                                    })}
                                </tbody>
                            </table>
                        </div>

                        {/* FOOTER DATABASE (Import/Export e Reset) */}
                        <div style={{ padding: '20px 40px', borderTop: '1px solid #E5E5EA', background: '#FFFFFF', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                            <div style={{ display: 'flex', gap: '15px' }}>
                                <button style={{ background: '#F5F5F7', border: 'none', padding: '10px 20px', borderRadius: '8px', cursor: 'pointer', fontSize: '13px', fontWeight: 600, color: '#1D1D1F' }} onClick={exportJSON}>
                                    Esporta Backup (JSON)
                                </button>
                                <button style={{ background: '#F5F5F7', border: 'none', padding: '10px 20px', borderRadius: '8px', cursor: 'pointer', fontSize: '13px', fontWeight: 600, color: '#1D1D1F' }} onClick={() => fileInputRef.current.click()}>
                                    Importa Dati
                                </button>
                                <input type="file" ref={fileInputRef} accept=".json" style={{ display: 'none' }} onChange={importJSON} />
                            </div>
                            
                            <button style={{ color: '#FF3B30', background: 'transparent', border: 'none', fontSize: '13px', fontWeight: 700, cursor: 'pointer', textDecoration: 'underline' }} onClick={resetDatabase}>
                                Ripristina Database di Default
                            </button>
                        </div>
                    </div>
                </div>
            )}
        </div>
    );
};
