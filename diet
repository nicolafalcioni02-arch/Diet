                                                    <th className="p-4 font-black text-gray-400 uppercase tracking-widest text-[10px] text-center">Età / Genere</th>
                                                    <th className="p-4 font-black text-green-500 uppercase tracking-widest text-[10px]">PRI / AR</th>
                                                    <th className="p-4 font-black text-blue-500 uppercase tracking-widest text-[10px]">AI</th>
                                                    <th className="p-4 font-black text-red-500 uppercase tracking-widest text-[10px]">UL (Max)</th>
                                                    <th className="p-4 font-black text-gray-400 uppercase tracking-widest text-[10px] text-center w-16"></th>
                                                </tr>
                                            </thead>
                                            <tbody className="divide-y divide-gray-50">
                                                {filteredDrv.map((row, idx) => {
                                                    // Troviamo l'indice reale nel database originale per le modifiche
                                                    const realIdx = drvDB.indexOf(row);
                                                    return (
                                                        <tr key={realIdx} className="hover:bg-blue-50/20 transition-colors group">
                                                            <td className="p-2">
                                                                <input className="w-full bg-transparent border border-transparent hover:border-gray-200 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 rounded-lg px-3 py-2 font-bold text-gray-900 outline-none transition-all truncate" value={row.Nutrient || ''} onChange={e => { const ndb = [...drvDB]; ndb[realIdx].Nutrient = e.target.value; setDrvDB(ndb); }} title={row.Nutrient}/>
                                                            </td>
                                                            <td className="p-2">
                                                                <input className="w-full bg-transparent border border-transparent hover:border-gray-200 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 rounded-lg px-3 py-2 font-medium text-gray-600 outline-none transition-all truncate" value={row["Target population"] || ''} onChange={e => { const ndb = [...drvDB]; ndb[realIdx]["Target population"] = e.target.value; setDrvDB(ndb); }} title={row["Target population"]} />
                                                            </td>
                                                            <td className="p-2">
                                                                <div className="flex gap-1">
                                                                    <input className="w-1/2 bg-transparent border border-transparent hover:border-gray-200 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 rounded-lg px-2 py-2 font-medium text-gray-600 outline-none transition-all text-center" value={row.Age || ''} onChange={e => { const ndb = [...drvDB]; ndb[realIdx].Age = e.target.value; setDrvDB(ndb); }} placeholder="Age" />
                                                                    <span className="text-gray-300 self-center">/</span>
                                                                    <input className="w-1/2 bg-transparent border border-transparent hover:border-gray-200 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 rounded-lg px-2 py-2 font-medium text-gray-600 outline-none transition-all text-center" value={row.Gender || ''} onChange={e => { const ndb = [...drvDB]; ndb[realIdx].Gender = e.target.value; setDrvDB(ndb); }} placeholder="Gender" />
                                                                </div>
                                                            </td>
                                                            <td className="p-2 relative group/pri">
                                                                <input className="w-full bg-transparent border border-transparent hover:border-green-200 focus:bg-white focus:border-green-500 focus:ring-4 focus:ring-green-500/10 rounded-lg px-3 py-2 font-black text-green-600 outline-none transition-all" value={row.PRI || row.AR || ''} onChange={e => { const ndb = [...drvDB]; if(row.PRI !== undefined) ndb[realIdx].PRI = e.target.value; else ndb[realIdx].AR = e.target.value; setDrvDB(ndb); }} placeholder="ND" />
                                                            </td>
                                                            <td className="p-2 relative group/ai">
                                                                <input className="w-full bg-transparent border border-transparent hover:border-blue-200 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 rounded-lg px-3 py-2 font-black text-blue-600 outline-none transition-all" value={row.AI || ''} onChange={e => { const ndb = [...drvDB]; ndb[realIdx].AI = e.target.value; setDrvDB(ndb); }} placeholder="ND" />
                                                            </td>
                                                            <td className="p-2 relative group/ul">
                                                                <input className="w-full bg-transparent border border-transparent hover:border-red-200 focus:bg-white focus:border-red-500 focus:ring-4 focus:ring-red-500/10 rounded-lg px-3 py-2 font-black text-red-500 outline-none transition-all" value={row.UL || ''} onChange={e => { const ndb = [...drvDB]; ndb[realIdx].UL = e.target.value; setDrvDB(ndb); }} placeholder="ND" />
                                                            </td>
                                                            <td className="p-2 text-center w-16">
                                                                <button onClick={() => {
                                                                    if(window.confirm("Eliminare definitivamente questo record?")) {
                                                                        const newDB = [...drvDB]; newDB.splice(realIdx, 1); setDrvDB(newDB);
                                                                    }
                                                                }} className="w-8 h-8 rounded-lg bg-white border border-gray-200 text-gray-400 hover:bg-red-50 hover:text-red-600 hover:border-red-200 font-bold transition-all shadow-sm opacity-0 group-hover:opacity-100 flex items-center justify-center mx-auto">
                                                                    <i className="ph-bold ph-trash"></i>
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    );
                                                })}
                                            </tbody>
                                        </table>
                                    )}
                                </div>
                            </div>

                            {/* FOOTER PER AGGIUNTA MANUALE */}
                            <div className="p-4 bg-white border-t border-gray-100 flex justify-center z-10 shrink-0 shadow-[0_-4px_15px_-3px_rgba(0,0,0,0.05)] rounded-b-[36px]">
                                <button onClick={() => {
                                    setDrvDB([{ Nutrient: "Nuovo Nutriente", "Target population": "Adults", Age: "18-39", Gender: "All", PRI: "10 mg/day", AI: "ND", UL: "ND" }, ...drvDB]);
                                    setDrvSearch('');
                                }} className="px-6 py-3 border border-gray-200 bg-gray-50 text-gray-700 rounded-2xl text-xs font-bold hover:bg-white hover:border-gray-300 hover:shadow-md transition-all flex items-center gap-2 group">
                                    <div className="w-6 h-6 rounded-full bg-white border border-gray-200 flex items-center justify-center group-hover:border-blue-300 group-hover:text-blue-500 transition-colors">
                                        <i className="ph-bold ph-plus"></i>
                                    </div>
                                    Crea Nuova Regola DRV Manuale
                                </button>
                            </div>
                        </div>
                    </div>
                );
            })()}
            
        </div>
    );
};
