                .bar-col { flex: 1; display: flex; flex-direction: column; justify-content: flex-end; align-items: center; gap: 5px; height: 100%; }
                .bar-fill { width: 100%; border-radius: 4px 4px 0 0; transition: height 0.5s ease; }
