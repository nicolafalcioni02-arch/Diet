                                    </div>
                                    <div className="flex items-center gap-4 text-xs">
                                        <div><span className="text-gray-400 block text-[9px] uppercase font-bold tracking-wider">Paziente</span><span className="font-black text-sm">{patientProfile.name}</span></div>
                                        <div className="w-px h-6 bg-white/20"></div>
                                        <div><span className="text-gray-400 block text-[9px] uppercase font-bold tracking-wider">Bio</span><span className="font-bold">{patientProfile.age} anni, {patientProfile.gender === 'Male' ? 'Uomo' : 'Donna'}, {patientProfile.weight}kg</span></div>
                                        <div className="w-px h-6 bg-white/20"></div>
                                        <div>
                                            <span className="text-gray-400 block text-[9px] uppercase font-bold tracking-wider">Avvertenze Cliniche</span>
                                            <div className="flex gap-2 mt-0.5">
                                                {patientProfile.allergies.map(a => <span key={a} className="bg-red-500/20 text-red-300 px-2 py-0.5 rounded text-[9px] font-bold border border-red-500/30">{a}</span>)}
                                                {patientProfile.pathologies.map(p => <span key={p} className="bg-amber-500/20 text-amber-300 px-2 py-0.5 rounded text-[9px] font-bold border border-amber-500/30">{p}</span>)}
                                                {patientProfile.notes && <span className="bg-blue-500/20 text-blue-300 px-2 py-0.5 rounded text-[9px] font-bold border border-blue-500/30 truncate max-w-[150px]">{patientProfile.notes}</span>}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div className="flex gap-2">
                                    <button onClick={() => setIsDrvEditorOpen(true)} className="px-4 py-2 bg-white/10 hover:bg-white/20 rounded-xl text-xs font-bold transition-colors flex items-center gap-2">
                                        <i className="ph-bold ph-database"></i> Database EFSA (DRV)
                                    </button>
                                    <button onClick={() => setIsAnalysisOpen(false)} className="w-10 h-10 bg-white/10 hover:bg-red-500/20 hover:text-red-400 rounded-xl flex items-center justify-center transition-colors">
                                        <i className="ph-bold ph-x"></i>
                                    </button>
                                </div>
                            </div>

                            {/* BARRA STRUMENTI & TIMEFRAME */}
                            <div className="px-8 py-4 bg-white border-b border-gray-100 flex justify-between items-center shrink-0 z-10 shadow-sm">
                                <div>
                                    <h3 className="text-xl font-black text-gray-900">Report Nutrizionale Molecolare</h3>
                                    <p className="text-xs font-bold text-gray-400 uppercase">Incrocio dati Database Alimenti e DRV Popolazione</p>
                                </div>
                                <div className="flex bg-gray-100 p-1 rounded-xl">
                                    {['meal', 'day', 'week'].map(tf => (
                                        <button 
                                            key={tf} onClick={() => setAnalysisTimeframe(tf)}
                                            className={`px-6 py-2 rounded-lg text-xs font-bold transition-all ${analysisTimeframe === tf ? 'bg-white text-black shadow-sm scale-100' : 'text-gray-500 hover:bg-gray-200'}`}
                                        >
                                            {tf === 'meal' ? 'Singolo Pasto (Media)' : tf === 'day' ? 'Media Giornaliera' : 'Totale Settimanale'}
                                        </button>
                                    ))}
                                </div>
                            </div>

                            {/* GRIGLIA CARD DINAMICHE */}
                            <div className="flex-1 overflow-y-auto p-8 bg-gray-50/50 custom-scrollbar">
                                
                                {/* COMPONENTI CON TARGET (EFSA) */}
                                <div className="mb-10">
                                    <h4 className="text-sm font-black text-gray-400 uppercase tracking-widest mb-4 flex items-center gap-2">
                                        <i className="ph-fill ph-target text-green-500 text-lg"></i> Micronutrienti Tracciati
                                    </h4>
                                    {Object.keys(patientTargets).length === 0 ? (
                                        <div className="p-8 border-2 border-dashed border-gray-200 rounded-2xl text-center text-gray-400 font-bold text-sm">
                                            Nessun target EFSA trovato. Assicurati di aver importato il database in alto a destra.
                                        </div>
                                    ) : (
                                        <div className="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4">
                                            {Object.entries(patientTargets).map(([key, ref]) => {
                                                const val = (currentProfile[key] || 0) * multiplier;
                                                const target = ref.target * multiplier;
                                                const ul = ref.ul ? ref.ul * multiplier : null;
                                                const pct = Math.min((val / target) * 100, 100);

                                                let status = 'ok';
                                                let statusColor = 'text-green-500';
                                                let bgColor = 'bg-green-500';
                                                let alertBox = null;

                                                if (val < target * 0.75) {
                                                    status = 'low'; statusColor = 'text-amber-500'; bgColor = 'bg-amber-400';
                                                    alertBox = "Deficit Rilevato";
                                                }
                                                if (ul && val > ul) {
                                                    status = 'high'; statusColor = 'text-red-500'; bgColor = 'bg-red-500';
                                                    alertBox = "Superamento UL (Tossicità)";
                                                }

                                                return (
                                                    <div key={key} className={`bg-white p-5 rounded-2xl border ${status === 'low' ? 'border-amber-200' : status === 'high' ? 'border-red-200' : 'border-gray-200'} shadow-sm relative overflow-hidden group hover:shadow-lg transition-all`}>
                                                        {status !== 'ok' && (
                                                            <div className={`absolute top-0 right-0 w-8 h-8 flex items-start justify-end p-2 ${status === 'low' ? 'bg-amber-50 text-amber-500' : 'bg-red-50 text-red-500'} rounded-bl-2xl`}>
                                                                <i className={`ph-fill ${status === 'low' ? 'ph-arrow-down' : 'ph-warning-octagon'}`}></i>
                                                            </div>
                                                        )}
                                                        <span className="text-[10px] font-black text-gray-400 uppercase tracking-wider block mb-1">{ref.name}</span>
                                                        <div className="flex items-baseline gap-1 mb-3">
                                                            <span className={`text-3xl font-black ${statusColor}`}>
                                                                {val.toFixed(1)}
                                                            </span>
                                                            <span className="text-xs font-bold text-gray-400">{ref.unit}</span>
                                                        </div>
                                                        
                                                        {/* ProgressBar con limite superiore visivo */}
                                                        <div className="h-2 w-full bg-gray-100 rounded-full overflow-hidden mb-2 relative">
                                                            <div className={`h-full transition-all duration-1000 ${bgColor}`} style={{ width: `${pct}%` }} />
                                                            {ul && <div className="absolute top-0 bottom-0 border-l-2 border-red-500 z-10" style={{ left: `${Math.min((ul/target)*100, 100)}%` }} title="Upper Level" />}
                                                        </div>
                                                        
                                                        <div className="flex justify-between items-center text-[9px] font-black uppercase text-gray-400">
                                                            <span>Target: {target.toFixed(1)}</span>
                                                            {ul && <span className="text-red-400">Max: {ul.toFixed(1)}</span>}
                                                        </div>

                                                        {alertBox && (
                                                            <div className={`mt-3 p-2 rounded-lg text-[10px] font-bold ${status === 'low' ? 'bg-amber-50 text-amber-700' : 'bg-red-50 text-red-700'}`}>
                                                                {alertBox}
                                                            </div>
                                                        )}
                                                    </div>
                                                );
                                            })}
                                        </div>
                                    )}
                                </div>

                                {/* ALTRI COMPONENTI DEL DATABASE (Es. Aminoacidi, Grassi specifici) */}
                                <div>
                                    <h4 className="text-sm font-black text-gray-400 uppercase tracking-widest mb-4 flex items-center gap-2">
                                        <i className="ph-fill ph-dots-three-circle text-gray-500 text-lg"></i> Altri Componenti Tracciati
                                    </h4>
                                    <div className="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3">
                                        {Object.entries(currentProfile).filter(([k, v]) => v > 0 && !patientTargets[k] && k !== 'energy_kcal').map(([key, val]) => (
                                            <div key={key} className="bg-white p-3 rounded-xl border border-gray-100 shadow-sm flex flex-col hover:border-gray-300 transition-colors">
                                                <span className="text-[9px] font-bold text-gray-400 uppercase tracking-wider truncate" title={key}>{key.replace(/_/g, ' ')}</span>
                                                <span className="text-sm font-black text-gray-800 mt-1">
                                                    {(val * multiplier).toFixed(2)}
                                                </span>
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                );
            })()}

            {/* --- MODALE 2: EDITOR DRV (EFSA) --- */}
            {isDrvEditorOpen && (
                <div className="fixed inset-0 z-[14000] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
                    <div className="bg-white rounded-2xl shadow-2xl w-full max-w-6xl h-[80vh] flex flex-col overflow-hidden">
                        
                        <div className="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50 shrink-0">
                            <div>
                                <h3 className="text-lg font-black text-gray-900">Configurazione Range Riferimento (DRV)</h3>
                                <span className="text-xs text-gray-500 font-bold">{drvDB.length} record importati dal JSON EFSA</span>
                            </div>
                            <div className="flex gap-2">
                                <button onClick={() => drvFileInputRef.current.click()} className="px-4 py-2 bg-white border border-gray-200 rounded-xl text-xs font-bold hover:bg-green-50 hover:text-green-600 transition-colors flex items-center gap-2 shadow-sm">
                                    <i className="ph-bold ph-upload-simple"></i> Importa JSON Popolazione
                                </button>
                                <input type="file" ref={drvFileInputRef} accept=".json" style={{ display: 'none' }} onChange={e => {
                                    const file = e.target.files[0];
                                    if (file) {
                                        const reader = new FileReader();
                                        reader.onload = (evt) => { setDrvDB(JSON.parse(evt.target.result)); alert("Database EFSA Caricato con successo!"); };
                                        reader.readAsText(file);
                                    }
                                }} />
                                
                                <button onClick={() => {
                                    const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(drvDB, null, 2));
                                    const a = document.createElement('a'); a.href = dataStr; a.download = "drv_custom.json"; a.click();
                                }} className="px-4 py-2 bg-white border border-gray-200 rounded-xl text-xs font-bold hover:bg-blue-50 hover:text-blue-600 transition-colors flex items-center gap-2 shadow-sm">
                                    <i className="ph-bold ph-download-simple"></i> Esporta Modifiche
                                </button>

                                <button onClick={() => setIsDrvEditorOpen(false)} className="w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center ml-4 hover:bg-gray-300 transition-colors">
                                    <i className="ph-bold ph-x text-lg"></i>
                                </button>
                            </div>
                        </div>

                        {/* Tabella Modificabile (Piena Libertà) */}
                        <div className="flex-1 overflow-auto p-0 custom-scrollbar">
                            {drvDB.length === 0 ? (
                                <div className="h-full flex flex-col items-center justify-center text-gray-400">
                                    <i className="ph-thin ph-database text-6xl mb-4"></i>
                                    <p className="font-bold">Nessun dato presente. Importa il JSON convertito.</p>
                                </div>
                            ) : (
                                <table className="w-full text-left text-xs">
                                    <thead className="bg-white sticky top-0 font-black text-gray-400 uppercase tracking-wider z-10 border-b border-gray-200 shadow-sm">
                                        <tr>
                                            <th className="p-4">Nutrient</th>
                                            <th className="p-4">Age</th>
                                            <th className="p-4">Gender</th>
                                            <th className="p-4 text-green-600">PRI / AR</th>
                                            <th className="p-4 text-blue-600">AI</th>
                                            <th className="p-4 text-red-500">UL (Limite)</th>
                                            <th className="p-4 text-center">Azioni</th>
                                        </tr>
                                    </thead>
                                    <tbody className="divide-y divide-gray-100">
                                        {drvDB.map((row, idx) => (
                                            <tr key={idx} className="hover:bg-gray-50 transition-colors">
                                                <td className="p-2"><input className="w-full bg-transparent border border-transparent hover:border-gray-200 focus:bg-white focus:border-green-500 rounded px-2 py-1 font-bold text-gray-900 outline-none" value={row.Nutrient || ''} onChange={e => { const ndb = [...drvDB]; ndb[idx].Nutrient = e.target.value; setDrvDB(ndb); }} /></td>
                                                <td className="p-2"><input className="w-full bg-transparent border border-transparent hover:border-gray-200 focus:bg-white focus:border-green-500 rounded px-2 py-1 outline-none" value={row.Age || ''} onChange={e => { const ndb = [...drvDB]; ndb[idx].Age = e.target.value; setDrvDB(ndb); }} /></td>
                                                <td className="p-2"><input className="w-full bg-transparent border border-transparent hover:border-gray-200 focus:bg-white focus:border-green-500 rounded px-2 py-1 outline-none" value={row.Gender || ''} onChange={e => { const ndb = [...drvDB]; ndb[idx].Gender = e.target.value; setDrvDB(ndb); }} /></td>
                                                <td className="p-2"><input className="w-full bg-transparent border border-transparent hover:border-gray-200 focus:bg-white focus:border-green-500 rounded px-2 py-1 font-bold text-green-600 outline-none" value={row.PRI || row.AR || ''} onChange={e => { const ndb = [...drvDB]; if(row.PRI) ndb[idx].PRI = e.target.value; else ndb[idx].AR = e.target.value; setDrvDB(ndb); }} /></td>
                                                <td className="p-2"><input className="w-full bg-transparent border border-transparent hover:border-gray-200 focus:bg-white focus:border-green-500 rounded px-2 py-1 font-bold text-blue-600 outline-none" value={row.AI || ''} onChange={e => { const ndb = [...drvDB]; ndb[idx].AI = e.target.value; setDrvDB(ndb); }} /></td>
                                                <td className="p-2"><input className="w-full bg-transparent border border-transparent hover:border-gray-200 focus:bg-white focus:border-green-500 rounded px-2 py-1 font-bold text-red-500 outline-none" value={row.UL || ''} onChange={e => { const ndb = [...drvDB]; ndb[idx].UL = e.target.value; setDrvDB(ndb); }} /></td>
                                                <td className="p-2 text-center">
                                                    <button onClick={() => {
                                                        if(window.confirm("Eliminare questa riga?")) {
                                                            const newDB = [...drvDB]; newDB.splice(idx, 1); setDrvDB(newDB);
                                                        }
                                                    }} className="w-8 h-8 rounded-lg bg-gray-100 hover:bg-red-100 hover:text-red-600 font-bold transition-colors">
                                                        <i className="ph-bold ph-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>
                            )}
                        </div>
                        <div className="p-4 bg-gray-50 border-t border-gray-100 flex justify-center">
                            <button onClick={() => {
                                setDrvDB([{ Nutrient: "Nuovo Nutriente", Age: "18-39", Gender: "All", PRI: "10 mg/day", AI: "ND", UL: "ND" }, ...drvDB]);
                            }} className="px-6 py-2 bg-black text-white rounded-xl text-xs font-bold hover:bg-gray-800 transition-colors shadow-md">
                                + Aggiungi Nuova Riga Manualmente
                            </button>
                        </div>
                    </div>
                </div>
            )}

            
        </div>
    );
};
