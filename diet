                                            <tr key={index} style={{ borderBottom: '1px solid #F5F5F7' }}>
                                                <td style={{ padding: '8px' }}><input value={f.name} onChange={e => updateDbFood(index, 'name', e.target.value)} style={{ width: '100%', border: '1px solid transparent', background: 'transparent', padding: '8px', borderRadius: '6px', fontSize: '14px', fontWeight: 600, color: '#1D1D1F', outline: 'none' }}/></td>
                                                <td style={{ padding: '8px' }}><input value={f.category} onChange={e => updateDbFood(index, 'category', e.target.value)} style={{ width: '100%', border: '1px solid transparent', background: 'transparent', padding: '8px', borderRadius: '6px', fontSize: '14px', color: '#86868B', outline: 'none' }}/></td>
                                                <td style={{ padding: '8px' }}><input type="number" value={f.kcal} onChange={e => updateDbFood(index, 'kcal', e.target.value)} style={{ width: '100%', border: '1px solid transparent', background: 'transparent', padding: '8px', borderRadius: '6px', fontSize: '14px', fontWeight: 700, color: '#1D1D1F', outline: 'none' }}/></td>
                                                <td style={{ padding: '8px' }}><input type="number" value={f.p} onChange={e => updateDbFood(index, 'p', e.target.value)} style={{ width: '100%', border: '1px solid transparent', background: 'transparent', padding: '8px', borderRadius: '6px', fontSize: '14px', color: '#1D1D1F', outline: 'none' }}/></td>
                                                <td style={{ padding: '8px' }}><input type="number" value={f.c} onChange={e => updateDbFood(index, 'c', e.target.value)} style={{ width: '100%', border: '1px solid transparent', background: 'transparent', padding: '8px', borderRadius: '6px', fontSize: '14px', color: '#1D1D1F', outline: 'none' }}/></td>
                                                <td style={{ padding: '8px' }}><input type="number" value={f.f} onChange={e => updateDbFood(index, 'f', e.target.value)} style={{ width: '100%', border: '1px solid transparent', background: 'transparent', padding: '8px', borderRadius: '6px', fontSize: '14px', color: '#1D1D1F', outline: 'none' }}/></td>
                                                <td style={{ padding: '8px', textAlign: 'center' }}>
                                                    <button onClick={() => deleteFoodDB(index)} style={{ background: 'transparent', border: 'none', color: '#FF3B30', fontWeight: 800, cursor: 'pointer', padding: '8px' }}>X</button>
                                                </td>
                                            </tr>
                                        )
                                    })}
                                </tbody>
                            </table>
                        </div>

                        {/* FOOTER DATABASE (Import/Export e Reset) */}
                        <div style={{ padding: '20px 40px', borderTop: '1px solid #E5E5EA', background: '#FFFFFF', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                            <div style={{ display: 'flex', gap: '15px' }}>
                                <button style={{ background: '#F5F5F7', border: 'none', padding: '10px 20px', borderRadius: '8px', cursor: 'pointer', fontSize: '13px', fontWeight: 600, color: '#1D1D1F' }} onClick={exportJSON}>
                                    Esporta Backup (JSON)
                                </button>
                                <button style={{ background: '#F5F5F7', border: 'none', padding: '10px 20px', borderRadius: '8px', cursor: 'pointer', fontSize: '13px', fontWeight: 600, color: '#1D1D1F' }} onClick={() => fileInputRef.current.click()}>
                                    Importa Dati
                                </button>
                                <input type="file" ref={fileInputRef} accept=".json" style={{ display: 'none' }} onChange={importJSON} />
                            </div>
                            
                            <button style={{ color: '#FF3B30', background: 'transparent', border: 'none', fontSize: '13px', fontWeight: 700, cursor: 'pointer', textDecoration: 'underline' }} onClick={resetDatabase}>
                                Ripristina Database di Default
                            </button>
                        </div>

                        
                    </div>
                </div>
            )}
            {/* --- MODALE SMART CHART MAKER --- */}
            {isSmartOpen && (
                <div className="modal-backdrop">
                    <div className="modal-window" style={{ maxWidth: '700px', height: 'auto' }}>
                        
                        <div style={{ padding: '25px 40px', borderBottom: '1px solid #F0F0F2', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                            <div>
                                <h3 style={{ fontSize: '22px', fontWeight: 800, margin: 0, color: '#1D1D1F' }}>Smart Report Maker</h3>
                                <span style={{ fontSize: '12px', color: '#86868B', fontWeight: 600 }}>Crea grafici personalizzati per l'analisi clinica</span>
                            </div>
                            <button onClick={() => setIsSmartOpen(false)} style={{ border: 'none', background: 'transparent', fontSize: '20px', cursor: 'pointer', color: '#86868B', fontWeight: 800 }}>X</button>
                        </div>
                        
                        <div style={{ padding: '40px', background: '#FAFAFC', display: 'flex', flexDirection: 'column', gap: '25px' }}>
                            
                            {/* PANNELLO DI CONTROLLO AVANZATO PLOTLY */}
                            {/* PANNELLO DI CONTROLLO AVANZATO PLOTLY */}
                            <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr 1fr', gap: '20px' }}>
                                
                                <div>
                                    <label className="t-input-floating" style={{ marginBottom: '8px' }}>Estensione Dati</label>
                                    <select 
                                        value={smartConfig.scope} 
                                        onChange={e => setSmartConfig({...smartConfig, scope: e.target.value})}
                                        style={{ width: '100%', padding: '12px', borderRadius: '8px', border: '1px solid #E5E5EA', fontSize: '14px', fontWeight: 600, outline: 'none', background: '#FFFFFF' }}>
                                        <option value="activeDay">Solo Giorno Corrente (Pasti)</option>
                                        <option value="allDays">Confronta Tutti i Giorni</option>
                                    </select>
                                </div>

                                <div>
                                    <label className="t-input-floating" style={{ marginBottom: '8px' }}>Tipo di Grafico</label>
                                    <select 
                                        value={smartConfig.type} 
                                        onChange={e => setSmartConfig({...smartConfig, type: e.target.value})}
                                        style={{ width: '100%', padding: '12px', borderRadius: '8px', border: '1px solid #E5E5EA', fontSize: '14px', fontWeight: 600, outline: 'none', background: '#FFFFFF' }}>
                                        <option value="bar">Istogramma</option>
                                        <option value="line">Linea di Tendenza</option>
                                        <option value="pie">Torta Composizione</option>
                                        <option value="mixed">Misto (Kcal vs Peso)</option>
                                        <option value="radar">Radar (Equilibrio Macro)</option>
                                        <option value="3d">Scatter 3D (Volumetrico)</option>
                                    </select>
                                </div>

                                <div>
                                    <label className="t-input-floating" style={{ marginBottom: '8px' }}>Metrica Principale</label>
                                    <select 
                                        value={smartConfig.metric} 
                                        onChange={e => setSmartConfig({...smartConfig, metric: e.target.value})}
                                        disabled={smartConfig.type === 'mixed' || smartConfig.type === '3d' || smartConfig.type === 'radar'}
                                        style={{ width: '100%', padding: '12px', borderRadius: '8px', border: '1px solid #E5E5EA', fontSize: '14px', fontWeight: 600, outline: 'none', background: smartConfig.type === 'mixed' || smartConfig.type === '3d' || smartConfig.type === 'radar' ? '#F5F5F7' : '#FFFFFF', color: smartConfig.type === 'mixed' || smartConfig.type === '3d' || smartConfig.type === 'radar' ? '#86868B' : '#1D1D1F' }}>
                                        <option value="kcal">Calorie Totali</option>
                                        <option value="macro">Confronto Macro (P/C/F)</option>
                                        <option value="p">Proteine (g)</option>
                                        <option value="c">Carboidrati (g)</option>
                                        <option value="f">Grassi (g)</option>
                                        <option value="weight">Volume (g)</option>
                                    </select>
                                </div>
                            </div>

                            <div style={{ background: '#FFFFFF', padding: '40px', borderRadius: '16px', border: '1px dashed #C7C7CC', textAlign: 'center', color: '#86868B' }}>
                                {/* Area segnaposto per il rendering futuro del grafico selezionato */}
                                {/* IL CONTENITORE DEL GRAFICO PLOTLY */}
                            <div style={{ background: '#FFFFFF', padding: '20px', borderRadius: '16px', border: '1px dashed #C7C7CC', height: '350px', position: 'relative' }}>
                                {/* Questo div viene "riempito" dalla funzione useEffect qua sopra */}
                                <div ref={plotRef} style={{ width: '100%', height: '100%' }}></div>
                            </div>
                            </div>

                            <div>
                                <label className="t-input-floating" style={{ marginBottom: '8px' }}>Note Cliniche e Commenti al Paziente</label>
                                <textarea 
                                    value={smartConfig.comment}
                                    onChange={e => setSmartConfig({...smartConfig, comment: e.target.value})}
                                    placeholder="Inserisci qui le tue osservazioni nutrizionali, variazioni consigliate o feedback sull'andamento..."
                                    style={{ width: '100%', padding: '16px', borderRadius: '12px', border: '1px solid #E5E5EA', fontSize: '14px', outline: 'none', minHeight: '120px', fontFamily: 'inherit', resize: 'vertical' }}
                                />
                            </div>

                        </div>

                        <div style={{ padding: '20px 40px', borderTop: '1px solid #F0F0F2', background: '#FFFFFF', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                            <button style={{ background: 'transparent', color: '#86868B', border: 'none', fontWeight: 700, cursor: 'pointer' }} onClick={() => setSmartConfig({type: 'bar', dataSource: 'kcal', comment: ''})}>
                                Resetta
                            </button>
                            {/* Nel footer del Modale Smart, sostituisci il bottone esistente con questo */}
                            <button onClick={saveSmartReport} style={{ background: '#00C853', color: 'white', padding: '12px 35px', borderRadius: '12px', border: 'none', fontWeight: 700, cursor: 'pointer' }}>
                                Salva
                            </button>
                        </div>
                    </div>
                </div>
            )}
        </div>
    );
};
