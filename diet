        return parseFloat(valStr.replace(/[^\d.-]/g, '')) || 0;
    };

    // Trova i target EFSA per il paziente corrente
    const getPatientTargets = () => {
        // Filtra il DB EFSA in base a Gender e Age del paziente
        // Nota: EFSA usa fasce d'età (es. "18-39 years"). Qui prendiamo tutti quelli applicabili al "Gender" o "All".
        const targets = {};
        drvDB.forEach(row => {
            if (row.Gender === patientProfile.gender || row.Gender === "All") {
                // Per semplificare: prendiamo l'ultimo valore valido (ideale: match esatto fascia d'età)
                const mappedKey = NUTRIENT_MAPPING[row.Nutrient];
                if (mappedKey) {
                    // Cerca il target migliore (PRI > AI > AR)
                    let targetVal = parseEFSAValue(row.PRI) || parseEFSAValue(row.AI) || parseEFSAValue(row.AR);
                    let ulVal = parseEFSAValue(row.UL);
                    
                    if (targetVal > 0) {
                        targets[mappedKey] = {
                            name: row.Nutrient,
                            target: targetVal,
                            ul: ulVal,
                            unit: String(row.PRI || row.AI || row.AR).replace(/[\d.\s]/g, '').replace('/day', '').trim() || 'mg'
                        };
                    }
                }
            }
        });
        return targets;
    };

    // --- MOTORE DI CALCOLO MICRONUTRIENTI ---
    const analyzeCompleteBioProfile = (dietDays) => {
        const analysis = {};
        
        // 1. Inizializza tutti i campi possibili a 0 basandosi sul template
        Object.keys(emptyFoodTemplate).forEach(k => analysis[k] = 0);

        // 2. Somma tutti gli alimenti di tutti i giorni
        dietDays.forEach(day => {
            day.meals.forEach(meal => {
                meal.items.forEach(item => {
                    const foodData = foodDB.find(f => f.name === item.name);
                    if (!foodData) return;
                    
                    const factor = (Number(item.weight) || 0) / 100;
                    Object.keys(emptyFoodTemplate).forEach(key => {
                        const val = Number(foodData[key]) || 0;
                        analysis[key] += (val * factor);
                    });
                });
            });
        });

        // 3. Calcola la Media giornaliera (dividendo per il numero di giorni nel piano)
        const dayCount = dietDays.length || 1;
        Object.keys(analysis).forEach(key => analysis[key] /= dayCount);

        return analysis;
    };

