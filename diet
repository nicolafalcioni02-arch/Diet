  .sc-panel {
    border-right: 1px solid #F0F0F2;
    background: #FAFAFC;
    padding: 24px 20px;
    display: flex; flex-direction: column; gap: 24px;
    overflow-y: auto;
    animation: fadeInPanel 0.35s 0.1s cubic-bezier(0.16,1,0.3,1) both;
